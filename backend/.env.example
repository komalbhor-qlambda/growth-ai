# ── App ────────────────────────────────────────────────────────────
APP_NAME=SME Growth AI
APP_ENV=development
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database (self-hosted PostgreSQL) ──────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sme_growth_ai
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/sme_growth_ai

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Qdrant ────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── AI ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small
CLAUDE_MODEL=claude-sonnet-4-20250514
AI_CONFIDENCE_THRESHOLD=0.70

# ── Razorpay ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── WhatsApp (Meta Business API) ──────────────────────────────────
WHATSAPP_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_API_URL=https://graph.facebook.com/v19.0

# ── AWS S3 (optional — for file storage) ─────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=sme-growth-ai-docs

# ── Sentry (optional) ─────────────────────────────────────────────
SENTRY_DSN=
